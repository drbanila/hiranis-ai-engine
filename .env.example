# =============================================================================
# Hirani's AI Engine — environment template
# Copy to .env.local and fill in values. .env.local is gitignored; never commit
# real keys. On Vercel, set these in Project Settings → Environment Variables.
# =============================================================================

# --- AI provider (free tier) -------------------------------------------------
# Google AI Studio free-tier key for Gemini (https://aistudio.google.com/apikey).
# Primary/default model (gemini-2.5-flash-lite). Used by @ai-sdk/google.
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Optional backup provider (OpenRouter / Qwen) ----------------------------
# OPTIONAL. When set, Hirani's AI Engine automatically falls back to Qwen via
# OpenRouter (https://openrouter.ai/keys) if Gemini's free-tier quota is
# exhausted. If left blank, the app shows the friendly quota message instead.
OPENROUTER_API_KEY=

# --- Vercel Protection Bypass for Automation ---------------------------------
# Enable "Protection Bypass for Automation" in Vercel project settings; Vercel
# generates and injects this secret automatically in deployments. Set it locally
# only if you want to test the automation bypass path against `next dev`.
VERCEL_AUTOMATION_BYPASS_SECRET=
